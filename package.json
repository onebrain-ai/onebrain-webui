{
  "name": "@onebrain-ai/webui",
  "version": "0.1.3",
  "private": false,
  "description": "OneBrain WebUI — the universal surface (2D CMS shell) for the OneBrain daemon. Obsidian replacement, runs the agent on any platform.",
  "license": "MIT OR Apache-2.0",
  "type": "module",
  "homepage": "https://github.com/onebrain-ai/onebrain-webui",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onebrain-ai/onebrain-webui.git"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node scripts/append-untracked-notices.mjs && node scripts/strip-legacy-fonts.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aiden0z/pptx-renderer": "^1.2.1",
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/language": "^6.12.3",
    "@codemirror/language-data": "^6.5.2",
    "@codemirror/state": "^6.6.0",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@codemirror/view": "^6.43.0",
    "@fontsource/chakra-petch": "^5.2.7",
    "@fontsource/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@lezer/markdown": "^1.6.4",
    "@maxgraph/core": "^0.23.0",
    "@preact/signals": "^2.0.4",
    "@replit/codemirror-minimap": "^0.5.2",
    "beautiful-mermaid": "^1.1.3",
    "codemirror-lang-hcl": "^0.1.0",
    "dompurify": "^3.4.11",
    "js-yaml": "^4.2.0",
    "katex": "^0.16.47",
    "mammoth": "^1.12.0",
    "mermaid": "^11.15.0",
    "pako": "^3.0.0",
    "preact": "^10.27.2",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@preact/preset-vite": "^2.10.2",
    "@testing-library/preact": "^3.2.4",
    "@types/dompurify": "^3.0.5",
    "@types/js-yaml": "^4.0.9",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^28.0.0",
    "rollup-plugin-license": "^3.7.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.1.8"
  }
}
